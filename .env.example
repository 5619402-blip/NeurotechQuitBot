# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# База данных PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/neurotech_quit

# Администраторы (Telegram ID через запятую)
ADMIN_TELEGRAM_IDS=123456789,987654321

# Внешний защищённый плеер
PLAYER_BASE_URL=https://player.example.com

# Telegram file_id для onboarding/rules видео (заполняется скриптом scripts/upload_media_to_telegram.js)
# Если пусто — бот ищет файл локально (только для dev)
INTRO_VIDEO_FILE_ID=
RULES_VIDEO_FILE_ID=

# Хранилище аудиофайлов
STORAGE_PROVIDER=s3
STORAGE_BUCKET=neurotech-audio
STORAGE_ACCESS_KEY=your_storage_access_key
STORAGE_SECRET_KEY=your_storage_secret_key

# Платёжный провайдер
PAYMENT_PROVIDER=
PAYMENT_TEST_MODE=true

# Webhook (для Telegram и server callback от плеера)
WEBHOOK_BASE_URL=https://your-server.example.com

# Одноразовые ссылки на плеер: Bothost HTTP redirect
# Публичный URL Express-сервера на Bothost (IP или домен + порт)
BOTHOST_API_URL=http://81.26.182.16:3000
# URL Vercel-плеера (без /player — путь добавляется автоматически)
VERCEL_PLAYER_BASE_URL=https://your-vercel-player.vercel.app

# Cron-задачи (напоминания, follow-up)
# false — cron отключён (по умолчанию для локальной разработки без PostgreSQL)
# true  — cron включён (для production)
CRON_ENABLED=false
